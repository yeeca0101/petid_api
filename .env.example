# Copy to .env and edit

# API
# 서비스 이름
APP_NAME=dogface-embedding-api
# API 기본 prefix
API_PREFIX=/v1
# 로그 레벨
LOG_LEVEL=INFO

# Model
# 기본 임베딩 모델 이름
MODEL_NAME=miewid
# 모델 캐시/가중치 저장 경로
HF_CACHE_DIR=./weights

# verification용 모델 이름
VERIFICATION_MODEL_NAME=miewid
# verification용 모델 소스
VERIFICATION_MIEWID_MODEL_SOURCE=models--conservationxlabs--miewid-msv3
# verification weight 방식
VERIFICATION_WEIGHT_MODE=hf   # auto|hf|ft


# reid용 모델 이름
REID_MODEL_NAME=miewid
# reid용 모델 소스
REID_MIEWID_MODEL_SOURCE=models--conservationxlabs--miewid-msv3
# reid weight 방식
REID_WEIGHT_MODE=ft           # auto|hf|ft
# reid finetune ckpt 경로
REID_MIEWID_FINETUNE_CKPT_PATH=weights/ft_v2/checkpoints/miewidv3-ft-best.ckpt

# Storage
# 업로드/생성 파일 저장 루트
STORAGE_DIR=./data
# compose 시작 시 DB 초기화 여부
RESET_DB_ON_START=0
# compose 시작 시 storage 초기화 여부
RESET_STORAGE_ON_START=0

# Detector (YOLO)
# detector 사용 여부
DETECTOR_ENABLED=true
# face keypoint 탐지용 대안 body 탐지 weights 경로
# YOLO_WEIGHTS_PATH=./weights/yolo/yolo26n-pose-finetuned-best.pt # face keypoint detection
# detector weights 경로
YOLO_WEIGHTS_PATH=./weights/yolo/yolo26x.pt # or segment (when using yolo26x-seg.pt)
# YOLO task 유형
YOLO_TASK=detect  # or segment (when using yolo26x-seg.pt)
# YOLO 입력 크기
YOLO_IMGSZ=640
# YOLO confidence threshold
YOLO_CONF=0.40
# YOLO IoU threshold
YOLO_IOU=0.35
# 탐지 클래스 id (cat=15, dog=16)
YOLO_CLASS_IDS=15,16
# crop padding 비율
CROP_PADDING=0.0
# bbox 최소 면적 비율
MIN_BBOX_AREA_RATIO=0.030
# seed 업로드에 최소 bbox 면적 적용 여부
APPLY_MIN_BBOX_AREA_TO_SEED=true
# daily 업로드에 최소 bbox 면적 적용 여부
APPLY_MIN_BBOX_AREA_TO_DAILY=true

# Optional: only provide at runtime when the API container should auto-download weights.
# Example:
# GOOGLE_DRIVE_URL=https://drive.google.com/file/d/...
# Google Drive weights download URL
GOOGLE_DRIVE_URL=

# Vector DB (Qdrant)
# 벡터 DB 종류
VECTOR_DB=qdrant
# Qdrant base URL
QDRANT_URL=http://qdrant:6333
# Qdrant collection name
QDRANT_COLLECTION=pet_instances_v1
# Qdrant API key
# QDRANT_API_KEY=

# PostgreSQL
# PostgreSQL host
POSTGRES_HOST=postgres
# PostgreSQL port
POSTGRES_PORT=5432
# PostgreSQL database name
POSTGRES_DB=petid
# PostgreSQL user
POSTGRES_USER=petid
# PostgreSQL password
POSTGRES_PASSWORD=petid_dev_password
# Full SQLAlchemy DB URL
DATABASE_URL=postgresql+psycopg://petid:petid_dev_password@postgres:5432/petid
# DB 커넥션 풀에 기본으로 유지할 연결 수. API/worker 동시 DB 작업량에 맞춰 조정
DB_POOL_SIZE=10
# 기본 pool이 모두 사용 중일 때 임시로 추가 허용할 연결 수. 너무 높이면 PostgreSQL max_connections를 압박할 수 있음
DB_MAX_OVERFLOW=20
# DB pool timeout seconds
DB_POOL_TIMEOUT_S=30
# 읽기 소스 기본값
READ_SOURCE_DEFAULT=filesystem
# dual write 사용 여부
ENABLE_DUAL_WRITE=false
# PostgreSQL queue 사용 여부
ENABLE_POSTGRES_QUEUE=true

# Ingest pipeline slot-based parallelism
# ingest worker slot 개수
INGEST_PIPELINE_SLOTS=2
# 모든 slot이 공유하는 dispatch queue 크기, slot 수 근처에서 낮은 두 자릿수 정도로 유지
INGEST_PIPELINE_LOCAL_QUEUE_CAPACITY=10
# 보수적인 VRAM 안전 여유
INGEST_PIPELINE_RECOMMEND_SAFETY_VRAM_GB=3
# 보수적인 RAM 안전 여유
INGEST_PIPELINE_RECOMMEND_SAFETY_RAM_GB=4
# runtime probe용 대표 이미지 경로
INGEST_PIPELINE_PROBE_IMAGE=app/tools/dog_0.jpg

# Ingest batch pipeline
# ingest worker가 여러 이미지 job을 모델에 넣는 방식.
# single: 기존 방식. 이미지 job 1개씩 detector/embedding 처리
# batch_embed_only: 이미지 job은 묶되 detector는 1장씩, crop embedding만 batch 처리
# batch_full: 이미지 job을 묶고 detector도 image batch, embedding도 crop batch 처리
INGEST_BATCH_PIPELINE_MODE=single
# 한 번에 모을 ingest image job 수. 예: 8 images
INGEST_JOB_BATCH_SIZE=8
# partial batch를 기다릴 최대 시간(ms). batch size가 꽉 차지 않아도 이 시간이 지나면 실행
INGEST_JOB_BATCH_MAX_WAIT_MS=100
# detector에 한 번에 넣을 image 수. batch_full 모드에서 사용
DETECTOR_BATCH_SIZE=8
# embedder에 한 번에 넣을 crop 수. 8 images에서 64 crops가 나오면 32/32 두 번 실행
EMBEDDER_CROP_BATCH_SIZE=32

# pgAdmin
# pgAdmin login email
PGADMIN_DEFAULT_EMAIL=admin@example.com
# pgAdmin login password
PGADMIN_DEFAULT_PASSWORD=admin
# pgAdmin port
PGADMIN_PORT=5050

# Compute
# device selector
DEVICE=cuda:0
# API 동시성 상한
MAX_CONCURRENCY=1

# Preprocess (for embedding)
# 모델 입력 크기
INPUT_SIZE=440

# Output
# 출력 dtype
OUTPUT_DTYPE=float32
# API 응답 포맷
RESPONSE_FORMAT=json

# 최대 업로드 바이트 수
MAX_IMAGE_BYTES=1572864000
