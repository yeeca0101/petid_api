# Copy to .env and edit

# API
APP_NAME=dogface-embedding-api
API_PREFIX=/v1
LOG_LEVEL=INFO

# Model
MODEL_NAME=miewid
HF_CACHE_DIR=./weights

VERIFICATION_MODEL_NAME=miewid
VERIFICATION_MIEWID_MODEL_SOURCE=models--conservationxlabs--miewid-msv3
VERIFICATION_WEIGHT_MODE=hf   # auto|hf|ft
VERIFICATION_MIEWID_FINETUNE_CKPT_PATH=

REID_MODEL_NAME=miewid
REID_MIEWID_MODEL_SOURCE=models--conservationxlabs--miewid-msv3
REID_WEIGHT_MODE=ft           # auto|hf|ft
REID_MIEWID_FINETUNE_CKPT_PATH=weights/ft_v2/checkpoints/miewidv3-ft-best.ckpt

# Storage
STORAGE_DIR=./data

# Detector (YOLO)
DETECTOR_ENABLED=true
# YOLO_WEIGHTS_PATH=./weights/yolo/yolo26n-pose-finetuned-best.pt # face keypoint detection
YOLO_WEIGHTS_PATH=./weights/yolo/yolo26x.pt # or segment (when using yolo26x-seg.pt)
YOLO_TASK=detect  # or segment (when using yolo26x-seg.pt)
YOLO_IMGSZ=640
YOLO_CONF=0.40
YOLO_IOU=0.35
YOLO_CLASS_IDS=15,16
CROP_PADDING=0.0
MIN_BBOX_AREA_RATIO=0.030
APPLY_MIN_BBOX_AREA_TO_SEED=true
APPLY_MIN_BBOX_AREA_TO_DAILY=true

# Optional: only provide at runtime when the API container should auto-download weights.
# Example:
# GOOGLE_DRIVE_URL=https://drive.google.com/file/d/...
GOOGLE_DRIVE_URL=



# Vector DB (Qdrant)
VECTOR_DB=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=pet_instances_v1
# QDRANT_API_KEY=

# PostgreSQL / migration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=petid
POSTGRES_USER=petid
POSTGRES_PASSWORD=petid_dev_password
# DATABASE_URL takes precedence when set.
DATABASE_URL=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT_S=30
READ_SOURCE_DEFAULT=filesystem
ENABLE_DUAL_WRITE=false
ENABLE_POSTGRES_QUEUE=false

# Queue / scheduler
QUEUE_LOCAL_CAPACITY=8
QUEUE_POLL_INTERVAL_MS=1000
QUEUE_LEASE_TIMEOUT_S=120
QUEUE_MAX_RETRIES_DEFAULT=3
SCHEDULER_LANE_COUNT=1
SCHEDULER_MAX_INFLIGHT_JOBS=1
SCHEDULER_ENABLE_MICRO_BATCHING=false
SCHEDULER_MAX_BATCH_ITEMS=16
SCHEDULER_MAX_BATCH_WAIT_MS=25

# Compute
DEVICE=cuda:0
MAX_CONCURRENCY=1
MAX_BATCH_SIZE=16

# Preprocess (for embedding)
INPUT_SIZE=440

# Output
OUTPUT_DTYPE=float32
RESPONSE_FORMAT=json

MAX_IMAGE_BYTES=1572864000
